# Sky Scrapper API via RapidAPI (Skyscanner data — real-time global flights)
# Sign up at https://rapidapi.com, subscribe to "Sky Scrapper" by apiheya (~$10/month Basic)
# Your key is shown on the API page under X-RapidAPI-Key
RAPIDAPI_KEY=your_rapidapi_key_here

# Travelpayouts token is no longer used — remove it from Vercel if present
# Xotelo (hotel prices) still requires no API key
